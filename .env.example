# n8n instance
N8N_BASE_URL=https://your-n8n-domain.com
N8N_API_KEY=your_n8n_public_api_key
N8N_WORKFLOW_ID=
N8N_WORKFLOW_NAME=Auto Blog Post Generation from Google Trends`nN8N_WEBHOOK_PATH=trend-blog`nN8N_WEBHOOK_ID=5c7459c0-cb2f-4839-94ea-14ed1da0bce9

# webhook delivery from scraper -> n8n
N8N_WEBHOOK_URL=https://your-n8n-domain.com/webhook/trend-blog
N8N_WEBHOOK_METHOD=POST
N8N_ACCESS_TOKEN=
N8N_WEBHOOK_AUTH_HEADER=Authorization

# AI/image providers used by n8n workflow deploy patcher
HF_TOKEN=hf_xxx

# next.js publish endpoint and auth
BLOG_API_URL=https://your-blog-domain.com/api/blog/create
BLOG_API_SECRET=replace_with_strong_secret

# scraper runtime
HEADLESS=true
APP_MODE=worker
RUN_ONCE=false
SCRAPE_INTERVAL_MINUTES=360
COUNTRY_DELAY_SECONDS=600
COUNTRIES=
OPENCLAW_WEBHOOK_URL=
