                  {
                      "parameters":  {
                                         "jsCode":  "const inputItems = $input.all();\nconst MIN_CONTENT_LENGTH = 100;\nconst out = [];\n\nfor (const item of inputItems) {\n  const data = item.json?.body ?? item.json;\n  if (!data || !Array.isArray(data.countries)) continue;\n\n  for (const c of data.countries) {\n    for (const trend of (c.trends || [])) {\n      const keyword = (trend.keyword || \"\").trim();\n      if (!keyword) continue;\n\n      const articles = Array.isArray(trend.articles) ? trend.articles : [];\n      const good = articles.filter(a =\u003e\n        a \u0026\u0026\n        a.success === true \u0026\u0026\n        typeof a.content === \"string\" \u0026\u0026\n        a.content.trim().length \u003e= MIN_CONTENT_LENGTH\n      );\n\n      if (!good.length) continue;\n\n      out.push({\n        json: {\n          keyword,\n          country: c.country || \"\",\n          geo: c.geo || \"\",\n          summary_for_ai: good\n            .map(a =\u003e (a.title ? `${a.title}\\n` : \"\") + a.content.slice(0, 700))\n            .join(\"\\n\\n---\\n\\n\"),\n        },\n      });\n    }\n  }\n}\n\nreturn out.length ? out.slice(0, 10) : [{ json: { error: \"No trends with sufficient content\" } }];\n"
                                     },
